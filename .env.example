# Copy to .env and fill in. Never commit .env.

# ── Server ──────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Insforge (database + file storage — replaces Bitrix in V2) ──
INSFORGE_API_BASE_URL=https://insforge.premierchoiceint.online
INSFORGE_API_KEY=
INSFORGE_TABLE=sales_partners
INSFORGE_BUCKET=sales-partner-documents

# ── App behaviour ───────────────────────────────────────────────
MAX_UPLOAD_MB=5
REFERRAL_BASE_URL=https://partners.premierchoiceint.online
TOS_VERSION=2026-07-v1

# Path to the fillable PDF template (see docs/PDF-TEMPLATE.md).
PDF_TEMPLATE_PATH=templates/SALES PARTNER REGISTRATION FORM (Digital).pdf

# ── Internal pages (link generator) ────────────────────────────
INTERNAL_BASIC_AUTH_USER=change-me
INTERNAL_BASIC_AUTH_PASS=change-me-to-a-long-random-string
