# Copy to .env and fill in. Never commit .env.

# ── Server ──────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Storage (local SQLite DB + uploaded files — both under the same
# Docker volume mount, see docker-compose.yml's /app/data volume) ──
DB_PATH=data/app.db
UPLOADS_DIR=data/uploads
PERSISTENT_STORAGE_PATH=data
REQUIRE_PERSISTENT_STORAGE=true

# ── App behaviour ───────────────────────────────────────────────
MAX_UPLOAD_MB=5
REFERRAL_BASE_URL=https://partners.premierchoiceint.online
TOS_VERSION=2026-07-v1

# Path to the fillable PDF template (see docs/PDF-TEMPLATE.md).
PDF_TEMPLATE_PATH=templates/SALES PARTNER REGISTRATION FORM (Digital).pdf

# ── Internal users / RBAC ──────────────────────────────────────
# Preferred: seed one or more named users with roles.
# Example JSON:
# INTERNAL_USERS=[{"username":"admin","password":"change-me","role":"admin","displayName":"PCI Admin"},{"username":"siddique","password":"change-me-too","role":"rep","displayName":"Siddique Akbar"}]
INTERNAL_USERS=

# Backward-compatible fallback: if INTERNAL_USERS is blank, this single
# shared admin account is seeded automatically.
INTERNAL_BASIC_AUTH_USER=change-me
INTERNAL_BASIC_AUTH_PASS=change-me-to-a-long-random-string
